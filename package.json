{
  "name": "presso-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/copy-runtime-assets.mjs",
    "test": "vitest run",
    "test:browser": "vitest run test/browser-smoke.test.ts",
    "dev": "npm run build && node packages/server/dist/cli.js dev examples/basic",
    "presso": "node packages/server/dist/cli.js",
    "release:check": "node scripts/check-publish-readiness.mjs",
    "release:pack": "node scripts/pack-workspaces.mjs --dry-run",
    "release:pack:write": "node scripts/pack-workspaces.mjs --write",
    "release:smoke-deck": "node scripts/smoke-generated-deck.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
