{
  "name": "@ajfisher/presso-create",
  "version": "0.3.3",
  "description": "Starter deck scaffolder for Presso.",
  "keywords": [
    "presso",
    "presentations",
    "markdown",
    "slides",
    "speaker-notes",
    "typescript",
    "static-site",
    "pdf-export"
  ],
  "homepage": "https://github.com/ajfisher/presso#readme",
  "bugs": {
    "url": "https://github.com/ajfisher/presso/issues"
  },
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajfisher/presso.git",
    "directory": "packages/create"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "presso-create": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  }
