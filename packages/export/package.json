{
  "name": "@ajfisher/presso-export",
  "version": "0.8.0",
  "description": "Static, transcript, and PDF export helpers for Presso.",
  "keywords": [
    "presso",
    "presentations",
    "markdown",
    "slides",
    "speaker-notes",
    "typescript",
    "static-site",
    "pdf-export"
  ],
  "homepage": "https://github.com/ajfisher/presso#readme",
  "bugs": {
    "url": "https://github.com/ajfisher/presso/issues"
  },
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajfisher/presso.git",
    "directory": "packages/export"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
