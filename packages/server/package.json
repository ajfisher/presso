{
  "name": "@ajfisher/presso-server",
  "version": "0.3.0",
  "description": "Presso CLI, dev server, controller sync, and authoring helpers.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ajfisher/presso.git",
    "directory": "packages/server"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
