    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@ajfisher/presso-core": "^0.3.0",
    "@ajfisher/presso-create": "^0.3.0",
    "@ajfisher/presso-export": "^0.3.0",
    "@ajfisher/presso-runtime": "^0.3.0"
  }
}
