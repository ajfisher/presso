{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bootstrap-sha": "58f5b2af4a7a251a4d09fbe93b3cf5ab8f535cd3",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "pull-request-title-pattern": "chore${scope}: release ${component} ${version}",
  "packages": {
    "packages/core": {
      "package-name": "@ajfisher/presso-core",
      "component": "@ajfisher/presso-core"
    },
    "packages/runtime": {
      "package-name": "@ajfisher/presso-runtime",
      "component": "@ajfisher/presso-runtime"
    },
    "packages/export": {
      "package-name": "@ajfisher/presso-export",
      "component": "@ajfisher/presso-export"
    },
    "packages/create": {
      "package-name": "@ajfisher/presso-create",
      "component": "@ajfisher/presso-create"
    },
    "packages/server": {
      "package-name": "@ajfisher/presso-server",
      "component": "@ajfisher/presso-server"
    }
  },
  "plugins": [
    {
      "type": "node-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "Presso packages",
      "components": [
        "@ajfisher/presso-core",
        "@ajfisher/presso-runtime",
        "@ajfisher/presso-export",
        "@ajfisher/presso-create",
        "@ajfisher/presso-server"
      ]
    }
  ]
}
